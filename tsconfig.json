{
	"compilerOptions": {
		"target": "es2024",
		"module": "node20",
		"moduleResolution": "node16",
		"lib": ["ES2024", "DOM"],
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"allowJs": true,
		"checkJs": false,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"noEmit": true
	},
	"include": ["src", "scripts", "tests", "frontend"],
	"exclude": ["node_modules", "dist"]
}
